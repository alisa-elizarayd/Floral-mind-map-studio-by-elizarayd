// 1. Функция загрузки библиотек
async function loadExportLibraries() {
    if (typeof htmlToImage === 'undefined') {
        await new Promise((resolve) => {
            const script = document.createElement('script');
            script.src = "https://unpkg.com/html-to-image@1.11.11/dist/html-to-image.js";
            script.onload = resolve;
            document.head.appendChild(script);
        });
    }
    
    if (typeof window.jspdf === 'undefined') {
        await new Promise((resolve) => {
            const script = document.createElement('script');
            script.src = "https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js";
            script.onload = resolve;
            document.head.appendChild(script);
        });
    }
}

// 2. Имя файла с датой
function getDateString() {
    const now = new Date();
    return `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}_${String(now.getHours()).padStart(2, '0')}-${String(now.getMinutes()).padStart(2, '0')}-${String(now.getSeconds()).padStart(2, '0')}`;
}

// 3. Показать/скрыть загрузку
let loadingOverlay = null;
function showLoading(show) {
    if (show && !loadingOverlay) {
        loadingOverlay = document.createElement('div');
        loadingOverlay.id = 'exportLoadingOverlay';
        loadingOverlay.style.cssText = `
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
        `;
        loadingOverlay.innerHTML = `
            <div style="background: white; border-radius: 24px; padding: 24px 32px; text-align: center;">
                <div style="width: 48px; height: 48px; border: 4px solid #FFB6C1; border-top-color: #C71585; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 16px;"></div>
                <p style="margin: 0; color: #511b3d;">🌸 Генерация...</p>
            </div>
            <style>@keyframes spin { to { transform: rotate(360deg); } }</style>
        `;
        document.body.appendChild(loadingOverlay);
    } else if (!show && loadingOverlay) {
        loadingOverlay.remove();
        loadingOverlay = null;
    }
}

// 4. Временное скрытие элементов интерфейса
function hideUIElements() {
    const zoomControls = document.querySelector('.zoom-controls');
    const introBtn = document.getElementById('openIntroBtn');
    const resizeHandles = document.querySelectorAll('.resize-handle');
    if (zoomControls) zoomControls.style.visibility = 'hidden';
    if (introBtn) introBtn.style.visibility = 'hidden';
    resizeHandles.forEach(h => h.style.visibility = 'hidden');
}

function showUIElements() {
    const zoomControls = document.querySelector('.zoom-controls');
    const introBtn = document.getElementById('openIntroBtn');
    const resizeHandles = document.querySelectorAll('.resize-handle');
    if (zoomControls) zoomControls.style.visibility = 'visible';
    if (introBtn) introBtn.style.visibility = 'visible';
    resizeHandles.forEach(h => h.style.visibility = 'visible');
}

// 5. Экспорт PNG (обычное качество)
async function exportPNG() {
    const container = document.getElementById('mapShell');
    if (!container) { alert("Контейнер не найден"); return; }
    
    showLoading(true);
// Временно убираем тени у всех узлов перед экспортом
