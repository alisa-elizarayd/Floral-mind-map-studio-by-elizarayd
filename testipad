// 7. Экспорт PDF (полная карта + отступы + тени + безопасная зона)
async function exportPDF() {
    const container = document.getElementById('mapShell');
    const stage = document.getElementById('mapStage');
    if (!container) { alert("Контейнер не найден"); return; }
    
    showLoading(true);
const allNodes = document.querySelectorAll('.node');
    const originalShadows = [];
    allNodes.forEach(node => {
        originalShadows.push({
            node,
            shadow: node.style.boxShadow
        });
        node.style.boxShadow = 'none';
    });
    hideUIElements();
    if (state.inlineEditingId && typeof closeInlineEditor === 'function') closeInlineEditor(true);
    
    // Сохраняем исходное состояние
    const originalOverflow = container.style.overflow;
    const originalPosition = stage.style.position;
    const originalPanX = state.panX;
    const originalPanY = state.panY;
    const originalScale = state.scale;
    
    try {
        // 1. Временно центрируем карту и убираем масштаб
        state.panX = 0;
        state.panY = 0;
        state.scale = 1;
        updateTransform();
        
        // 2. Снимаем все ограничения overflow
        container.style.overflow = 'visible';
        stage.style.position = 'relative';
        
        // Даём время на перерендер
        await new Promise(r => setTimeout(r, 150));
        
        // 3. Находим ВСЕ элементы, которые могут влиять на границы
        const nodes = document.querySelectorAll('.node');
        const lines = document.querySelectorAll('.line');
        const edgesSvg = document.getElementById('edges');
        
        if (nodes.length === 0) {
            throw new Error("Нет узлов для экспорта");
        }
        
        // 4. Вычисляем bounding box с учётом узлов, линий и теней
        let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
        
        // Учитываем узлы с их тенями (тени добавляют ~20px к размеру)
        nodes.forEach(node => {
            const left = parseFloat(node.style.left);
            const top = parseFloat(node.style.top);
            const width = node.offsetWidth;
            const height = node.offsetHeight;
            
            // Узлы центрированы через translate(-50%, -50%)
            const nodeLeft = left - width / 2;
            const nodeRight = left + width / 2;
            const nodeTop = top - height / 2;
            const nodeBottom = top + height / 2;
            
            // Добавляем запас на тени (25px с каждой стороны)
            const shadowPadding = 25;
            
            minX = Math.min(minX, nodeLeft - shadowPadding);
            maxX = Math.max(maxX, nodeRight + shadowPadding);
            minY = Math.min(minY, nodeTop - shadowPadding);
            maxY = Math.max(maxY, nodeBottom + shadowPadding);
        });
        
        // Учитываем линии (если они есть)
        if (edgesSvg) {
            const linePaths = edgesSvg.querySelectorAll('.line');
            linePaths.forEach(line => {
                const bbox = line.getBBox();
                if (bbox.x !== undefined) {
                    minX = Math.min(minX, bbox.x - 15);
                    minY = Math.min(minY, bbox.y - 15);
                    maxX = Math.max(maxX, bbox.x + bbox.width + 15);
                    maxY = Math.max(maxY, bbox.y + bbox.height + 15);
                }
            });
        }
        
        // 5. БЕЗОПАСНАЯ ЗОНА: добавляем большие отступы (80px со всех сторон)
        const safePadding = 80;
        const cropX = minX - safePadding;
        const cropY = minY - safePadding;
        const cropWidth = (maxX - minX) + safePadding * 2;
        const cropHeight = (maxY - minY) + safePadding * 2;
        
        console.log(`📐 Границы карты: minX=${minX}, maxX=${maxX}, ширина=${maxX-minX}`);
        console.log(`📐 С отступами: ширина=${cropWidth}, высота=${cropHeight}`);
        
        // 6. Делаем снимок с высоким разрешением
        const canvas = await htmlToImage.toCanvas(container, {
            pixelRatio: 3,           // Высокое разрешение для чёткости
            backgroundColor: container.style.background || '#FFE4EE',
            quality: 1,
            width: cropWidth,
            height: cropHeight,
            style: {
                transform: `translate(${-cropX}px, ${-cropY}px)`,
                transformOrigin: 'top left'
            },
            // Важные параметры для html-to-image
            skipAutoScale: false,
            cacheBust: true,
            includeQueryParams: true
        });
        
        const { jsPDF } = window.jspdf;
        
        const canvasWidth = canvas.width;
        const canvasHeight = canvas.height;
        
        // 7. Формат A4 в мм
        const pdfWidth = 210;
        let pdfHeight = (canvasHeight * pdfWidth) / canvasWidth;
        
        // 8. Определяем ориентацию
        const orientation = pdfHeight > 297 ? 'portrait' : 'landscape';
        let finalPdfWidth, finalPdfHeight;
        
        if (orientation === 'portrait') {
            finalPdfWidth = 210;
            finalPdfHeight = Math.min(pdfHeight, 297);
            // Если контент выше A4, масштабируем пропорционально
            if (pdfHeight > 297) {
                const scale = 297 / pdfHeight;
                finalPdfWidth = pdfWidth * scale;
                finalPdfHeight = 297;
            }
        } else {
            finalPdfWidth = 297;
            finalPdfHeight = (canvasHeight * 297) / canvasWidth;
            if (finalPdfHeight > 210) {
                const scale = 210 / finalPdfHeight;
                finalPdfWidth = 297 * scale;
                finalPdfHeight = 210;
            }
        }
        
        const pdf = new jsPDF({
            unit: 'mm',
            format: orientation === 'portrait' ? 'a4' : 'a4',
            orientation: orientation
        });
        
        const imgData = canvas.toDataURL('image/jpeg', 0.98);
        
        // Центрируем изображение на странице (если оно меньше)
        const xOffset = (finalPdfWidth < (orientation === 'portrait' ? 210 : 297)) 
            ? ((orientation === 'portrait' ? 210 : 297) - finalPdfWidth) / 2 
            : 0;
        const yOffset = (finalPdfHeight < (orientation === 'portrait' ? 297 : 210)) 
            ? ((orientation === 'portrait' ? 297 : 210) - finalPdfHeight) / 2 
            : 0;
        
        pdf.addImage(imgData, 'JPEG', xOffset, yOffset, finalPdfWidth, finalPdfHeight);
        pdf.save(`mindmap_${getDateString()}.pdf`);
        
        setStatus("✅ PDF сохранён! Вся карта с отступами на месте.");
        
    } catch (error) {
        console.error('PDF ошибка:', error);
        setStatus("❌ Ошибка PDF: " + error.message, true);
    } finally {
// Возвращаем тени обратно
        originalShadows.forEach(({ node, shadow }) => {
            node.style.boxShadow = shadow;
        });
        // 9. Восстанавливаем всё как было
        container.style.overflow = originalOverflow;
        stage.style.position = originalPosition;
        state.panX = originalPanX;
        state.panY = originalPanY;
        state.scale = originalScale;
        updateTransform();
        
        showUIElements();
        showLoading(false);
        if (typeof render === 'function') render();
    }
}


